{
  "actions": {
    "git_status": {
      "cmd": ["git", "status"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Show git working tree status"
    },
    "git_log": {
      "cmd": ["git", "log", "--oneline", "-20"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Show recent git log"
    },
    "git_diff": {
      "cmd": ["git", "diff"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Show git diff"
    },
    "git_branch": {
      "cmd": ["git", "branch", "-a"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "List git branches"
    },
    "git_add_all": {
      "cmd": ["git", "add", "-A"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Stage all changes"
    },
    "git_add": {
      "cmd": ["git", "add", "{paths}"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "params": {
        "paths": {"type": "string", "max_length": 1000, "split": true}
      },
      "description": "Stage specific paths"
    },
    "git_commit": {
      "cmd": ["git", "commit", "-m", "{message}"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "params": {
        "message": {"type": "string", "max_length": 500}
      },
      "description": "Commit staged changes"
    },
    "git_push": {
      "cmd": ["git", "push"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Push to remote"
    },
    "git_pull": {
      "cmd": ["git", "pull"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Pull from remote"
    },
    "git_stash": {
      "cmd": ["git", "stash"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Stash changes"
    },
    "git_stash_pop": {
      "cmd": ["git", "stash", "pop"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "description": "Pop stashed changes"
    },
    "git_merge": {
      "cmd": ["git", "merge", "{branch}"],
      "level": "confirm",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "params": {
        "branch": {"type": "string", "max_length": 100}
      },
      "description": "Merge a branch (history-altering)"
    },
    "git_rebase": {
      "cmd": ["git", "rebase", "{branch}"],
      "level": "confirm",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge", "~/Documents/mybrain-tv-*", "~/Documents/mybrain.tv", "~/Documents/dent"],
      "params": {
        "branch": {"type": "string", "max_length": 100}
      },
      "description": "Rebase onto a branch (history-altering)"
    },
    "rm_git_lock": {
      "cmd": ["rm", "-f", "{lockfile}"],
      "level": "allow",
      "working_dirs": ["~/Documents/buddy-*", "~/Documents/virtio-bridge"],
      "params": {
        "lockfile": {"type": "string", "enum": [".git/index.lock", ".git/HEAD.lock"]}
      },
      "description": "Remove git lock files"
    },
    "ls": {
      "cmd": ["ls", "-la"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "description": "List directory contents"
    },
    "check_port": {
      "cmd": ["lsof", "-i", ":{port}", "-P", "-n"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "params": {
        "port": {"type": "string", "max_length": 5}
      },
      "description": "Check if a port is in use"
    },
    "ps_grep": {
      "cmd": ["bash", "-c", "ps aux | grep {pattern} | grep -v grep"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "params": {
        "pattern": {"type": "string", "max_length": 100}
      },
      "description": "Search running processes"
    },
    "service_restart": {
      "cmd": ["launchctl", "kickstart", "-k", "gui/501/{service}"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "params": {
        "service": {"type": "string", "enum": [
          "com.virtio-bridge.server",
          "com.buddy.webrender-server",
          "com.buddy.a2e-server",
          "com.buddy.vllm-mlx",
          "com.buddy.memory-api"
        ]}
      },
      "description": "Restart a launchd service"
    },
    "service_status": {
      "cmd": ["launchctl", "list", "{service}"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "params": {
        "service": {"type": "string", "enum": [
          "com.virtio-bridge.server",
          "com.buddy.webrender-server",
          "com.buddy.a2e-server",
          "com.buddy.vllm-mlx",
          "com.buddy.memory-api"
        ]}
      },
      "description": "Check launchd service status"
    },
    "tail_log": {
      "cmd": ["tail", "-n", "{lines}", "{logfile}"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "params": {
        "logfile": {"type": "string", "enum": [
          "/tmp/buddy-memory-api.log",
          "/tmp/buddy-memory-api.err",
          "/tmp/virtio-bridge.log",
          "/tmp/virtio-bridge.err",
          "/tmp/buddy-vllm-mlx.log",
          "/tmp/buddy-vllm-mlx.err",
          "/tmp/buddy-webrender-server.log",
          "/tmp/buddy-webrender-server.err",
          "/tmp/buddy-a2e-server.log",
          "/tmp/buddy-a2e-server.err"
        ]},
        "lines": {"type": "string", "max_length": 4}
      },
      "description": "Read last N lines from a specific log file"
    },
    "memory_api_health": {
      "cmd": ["curl", "-s", "--max-time", "5", "http://localhost:11436/memory/health"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "description": "GET memory-api /memory/health"
    },
    "memory_api_post": {
      "cmd": ["curl", "-s", "--max-time", "180", "-X", "POST", "-H", "Content-Type: application/json", "-d", "{body}", "http://localhost:11436/memory/{endpoint}"],
      "level": "allow",
      "working_dirs": ["~/Documents"],
      "params": {
        "endpoint": {"type": "string", "enum": ["generate", "validate", "save-parallel", "evaluate", "learn"]},
        "body": {"type": "string", "max_length": 80000}
      },
      "description": "POST JSON body to memory-api endpoint (localhost:11436/memory/{endpoint})"
    }
  }
}
